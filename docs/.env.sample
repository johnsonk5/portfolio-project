# Core paths
PORTFOLIO_DATA_DIR=data
# Optional explicit DuckDB file path override
# PORTFOLIO_DUCKDB_PATH=data/duckdb/portfolio.duckdb

# Demo bootstrap source (clone -> bootstrap flow)
# Recommended: GitHub Release source by repo + exact asset name.
DEMO_DATA_REPO=yourorg/yourrepo
DEMO_DATA_ASSET=portfolio-demo-data-v1.zip
# Use latest release by default.
DEMO_DATA_RELEASE=latest
# Optional pinned release tag for reproducible demos.
# DEMO_DATA_TAG=v1.0.0-demo
# Token env name used by bootstrap (defaults to GITHUB_TOKEN).
DEMO_DATA_GITHUB_TOKEN_ENV=GITHUB_TOKEN
# Optional GitHub token to avoid API rate limits.
# GITHUB_TOKEN=ghp_xxx

# Fallback demo sources (used only if DEMO_DATA_REPO/ASSET not set)
DEMO_DATA_ZIP_LOCAL_PATH=demo/demo_data.zip
# DEMO_DATA_ZIP_URL=https://github.com/yourorg/yourrepo/releases/download/v1.0.0-demo/portfolio-demo-data-v1.zip
DEMO_DATA_TIMEOUT_SECONDS=30

# Alpaca credentials (required for Alpaca assets)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Universe + partitions
ALPACA_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA
ALPACA_PARTITIONS_START_DATE=2020-01-01

# Wikipedia / Wikidata
WIKIPEDIA_PROJECT=en.wikipedia.org
WIKIMEDIA_USER_AGENT=portfolio-project/0.1 (contact: you@example.com)
WIKIDATA_USER_AGENT=portfolio-project/0.1 (contact: you@example.com)
WIKIDATA_MAX_TICKER_BATCH=200
WIKIDATA_RETRY_SLEEP_SECONDS=2
WIKIPEDIA_MIN_ASSETS_WITH_VIEWS=400

# News / publisher weighting
DEFAULT_PUBLISHER_WEIGHT=0.05
TRANCO_LOOKUP_DAYS=30
# Optional CSV with columns: publisher_name,publisher_domain
# PUBLISHER_DOMAIN_MAP_PATH=data/reference/publisher_domains.csv
NEWS_SENTIMENT_BATCH_SIZE=32

# Tranco source
TRANCO_LIST_ID=GVL2K
# Optional fallback if not using list id:
# TRANCO_URL=https://tranco-list.eu/top-1m.csv

# Data quality thresholds
DQ_PRICES_NULL_PCT_THRESHOLD=0.0
DQ_GOLD_PRICES_CORE_NULL_PCT_THRESHOLD=0.0
DQ_NEWS_BOTH_TITLE_LINK_NULL_PCT_THRESHOLD=0.0
DQ_WIKIPEDIA_ASSET_ID_NULL_PCT_THRESHOLD=0.25
DQ_SP500_SYMBOL_NULL_PCT_THRESHOLD=0.0
DQ_SP500_ASSET_ID_NULL_PCT_THRESHOLD=0.25
DQ_ASSETS_CORE_NULL_PCT_THRESHOLD=0.0
